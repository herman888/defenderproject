<?xml version="1.0"?>
<!--
  Military interceptor quadrotor.
  Compact body, thin diagonal arms, cyan front rotors / white rear rotors,
  four landing-gear struts.  _apply_color("multi") preserves these colours.
-->
<robot name="interceptor_quad">

  <!-- ── Central body (octagonal approximation) ───────────────────────── -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.0130" ixy="0.0" ixz="0.0"
               iyy="0.0130" iyz="0.0"
               izz="0.0240"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.26 0.26 0.09"/></geometry>
      <material name="body_blue">
        <color rgba="0.10 0.15 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.26 0.26 0.09"/></geometry>
    </collision>
  </link>

  <!-- ── Arm 0 (front-right) ──────────────────────────────────────────── -->
  <link name="arm_0">
    <inertial>
      <mass value="0.045"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.028 0.028"/></geometry>
      <material name="arm_blue"><color rgba="0.12 0.18 0.45 1.0"/></material>
    </visual>
  </link>
  <joint name="arm_0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_0"/>
    <origin xyz="0.21 -0.21 0" rpy="0 0 -0.7854"/>
  </joint>

  <!-- ── Arm 1 (front-left) ────────────────────────────────────────────── -->
  <link name="arm_1">
    <inertial>
      <mass value="0.045"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.028 0.028"/></geometry>
      <material name="arm_blue"><color rgba="0.12 0.18 0.45 1.0"/></material>
    </visual>
  </link>
  <joint name="arm_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_1"/>
    <origin xyz="0.21 0.21 0" rpy="0 0 0.7854"/>
  </joint>

  <!-- ── Arm 2 (back-left) ─────────────────────────────────────────────── -->
  <link name="arm_2">
    <inertial>
      <mass value="0.045"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.028 0.028"/></geometry>
      <material name="arm_blue"><color rgba="0.12 0.18 0.45 1.0"/></material>
    </visual>
  </link>
  <joint name="arm_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_2"/>
    <origin xyz="-0.21 0.21 0" rpy="0 0 2.3562"/>
  </joint>

  <!-- ── Arm 3 (back-right) ────────────────────────────────────────────── -->
  <link name="arm_3">
    <inertial>
      <mass value="0.045"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.028 0.028"/></geometry>
      <material name="arm_blue"><color rgba="0.12 0.18 0.45 1.0"/></material>
    </visual>
  </link>
  <joint name="arm_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_3"/>
    <origin xyz="-0.21 -0.21 0" rpy="0 0 -2.3562"/>
  </joint>

  <!-- ── Rotor 0 front-right — CYAN ────────────────────────────────────── -->
  <link name="rotor_0">
    <inertial>
      <mass value="0.012"/>
      <inertia ixx="0.000014" ixy="0" ixz="0" iyy="0.000014" iyz="0" izz="0.000024"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.15" length="0.009"/></geometry>
      <material name="cyan"><color rgba="0.15 0.80 0.90 0.90"/></material>
    </visual>
  </link>
  <joint name="rotor_0_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_0"/>
    <origin xyz="0.360 -0.360 0.052" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ── Rotor 1 front-left — CYAN ─────────────────────────────────────── -->
  <link name="rotor_1">
    <inertial>
      <mass value="0.012"/>
      <inertia ixx="0.000014" ixy="0" ixz="0" iyy="0.000014" iyz="0" izz="0.000024"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.15" length="0.009"/></geometry>
      <material name="cyan"><color rgba="0.15 0.80 0.90 0.90"/></material>
    </visual>
  </link>
  <joint name="rotor_1_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_1"/>
    <origin xyz="0.360 0.360 0.052" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ── Rotor 2 back-left — WHITE ─────────────────────────────────────── -->
  <link name="rotor_2">
    <inertial>
      <mass value="0.012"/>
      <inertia ixx="0.000014" ixy="0" ixz="0" iyy="0.000014" iyz="0" izz="0.000024"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.15" length="0.009"/></geometry>
      <material name="white"><color rgba="0.88 0.88 0.88 0.90"/></material>
    </visual>
  </link>
  <joint name="rotor_2_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_2"/>
    <origin xyz="-0.360 0.360 0.052" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ── Rotor 3 back-right — WHITE ────────────────────────────────────── -->
  <link name="rotor_3">
    <inertial>
      <mass value="0.012"/>
      <inertia ixx="0.000014" ixy="0" ixz="0" iyy="0.000014" iyz="0" izz="0.000024"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.15" length="0.009"/></geometry>
      <material name="white"><color rgba="0.88 0.88 0.88 0.90"/></material>
    </visual>
  </link>
  <joint name="rotor_3_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_3"/>
    <origin xyz="-0.360 -0.360 0.052" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ── Landing gear: 4 struts ────────────────────────────────────────── -->
  <link name="gear_fr">
    <inertial><mass value="0.015"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.010" length="0.110"/></geometry>
      <material name="gear_gray"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>
  </link>
  <joint name="gear_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gear_fr"/>
    <origin xyz="0.10 -0.10 -0.100" rpy="0 0 0"/>
  </joint>

  <link name="gear_fl">
    <inertial><mass value="0.015"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.010" length="0.110"/></geometry>
      <material name="gear_gray"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>
  </link>
  <joint name="gear_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gear_fl"/>
    <origin xyz="0.10 0.10 -0.100" rpy="0 0 0"/>
  </joint>

  <link name="gear_bl">
    <inertial><mass value="0.015"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.010" length="0.110"/></geometry>
      <material name="gear_gray"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>
  </link>
  <joint name="gear_bl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gear_bl"/>
    <origin xyz="-0.10 0.10 -0.100" rpy="0 0 0"/>
  </joint>

  <link name="gear_br">
    <inertial><mass value="0.015"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.010" length="0.110"/></geometry>
      <material name="gear_gray"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>
  </link>
  <joint name="gear_br_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gear_br"/>
    <origin xyz="-0.10 -0.10 -0.100" rpy="0 0 0"/>
  </joint>

</robot>
