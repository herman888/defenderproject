<?xml version="1.0"?>
<robot name="quadrotor">

  <!-- Central body -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.0129" ixy="0.0" ixz="0.0"
               iyy="0.0129" iyz="0.0"
               izz="0.0250"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.2"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Rotor arm 0 (front-right) -->
  <link name="arm_0">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 0.04 0.04"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="arm_0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_0"/>
    <origin xyz="0.25 -0.25 0" rpy="0 0 -0.785"/>
  </joint>

  <!-- Rotor arm 1 (front-left) -->
  <link name="arm_1">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 0.04 0.04"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="arm_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_1"/>
    <origin xyz="0.25 0.25 0" rpy="0 0 0.785"/>
  </joint>

  <!-- Rotor arm 2 (back-left) -->
  <link name="arm_2">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 0.04 0.04"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="arm_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_2"/>
    <origin xyz="-0.25 0.25 0" rpy="0 0 2.356"/>
  </joint>

  <!-- Rotor arm 3 (back-right) -->
  <link name="arm_3">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 0.04 0.04"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="arm_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_3"/>
    <origin xyz="-0.25 -0.25 0" rpy="0 0 -2.356"/>
  </joint>

  <!-- Rotor 0 (front-right) -->
  <link name="rotor_0">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.22" length="0.01"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.9 0.8"/>
      </material>
    </visual>
  </link>
  <joint name="rotor_0_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_0"/>
    <origin xyz="0.354 -0.354 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rotor 1 (front-left) -->
  <link name="rotor_1">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.22" length="0.01"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.9 0.8"/>
      </material>
    </visual>
  </link>
  <joint name="rotor_1_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_1"/>
    <origin xyz="0.354 0.354 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rotor 2 (back-left) -->
  <link name="rotor_2">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.22" length="0.01"/>
      </geometry>
      <material name="red">
        <color rgba="0.9 0.1 0.1 0.8"/>
      </material>
    </visual>
  </link>
  <joint name="rotor_2_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_2"/>
    <origin xyz="-0.354 0.354 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rotor 3 (back-right) -->
  <link name="rotor_3">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.22" length="0.01"/>
      </geometry>
      <material name="red">
        <color rgba="0.9 0.1 0.1 0.8"/>
      </material>
    </visual>
  </link>
  <joint name="rotor_3_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_3"/>
    <origin xyz="-0.354 -0.354 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
